		<properties node_id="26" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 2, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x00\xf9\x00\x00\x00\xa2\x00\x00\x04\x08\x00\x00\x02\xa0\x00\x00\x00\xfa\x00\x00\x00\xc0\x00\x00\x04\x07\x00\x00\x02\x9f\x00\x00\x00\x00\x00\x00\x00\x00\x05\x00\x00\x00\x00\xfa\x00\x00\x00\xc0\x00\x00\x04\x07\x00\x00\x02\x9f', 'scriptLibrary': [{'name': 'correlation_matrix_widget.py', 'script': 'import numpy as np\nfrom Orange.widgets import widget, gui\nfrom Orange.widgets.settings import Setting\nfrom Orange.data import Table, Domain, ContinuousVariable\nfrom PyQt5.QtWidgets import QApplication, QTableWidget, QTableWidgetItem, QVBoxLayout\n\nclass CorrelationMatrixWidget(widget.OWWidget):\n    name = "Correlation Matrix"\n    description = "Generate a correlation matrix from a list of triples"\n    icon = "icons/correlation_matrix.svg"\n\n    class Inputs:\n        data = None\n\n    class Outputs:\n        correlation_matrix = None\n\n    want_main_area = False\n\n    def __init__(self):\n        super().__init__()\n        self.input_data = None\n        self.correlation_matrix = None\n        self.table_widget = QTableWidget()\n        layout = QVBoxLayout()\n        layout.addWidget(self.table_widget)\n        self.controlArea.setLayout(layout)\n\n    def set_input_data(self, data):\n        self.input_data = data\n        self.generate_correlation_matrix()\n\n    def generate_correlation_matrix(self):\n        if self.input_data is None:\n            return\n\n        # Get unique parameters\n        parameters = set()\n        for param1, param2, _ in self.input_data:\n            parameters.add(param1)\n            parameters.add(param2)\n\n        # Create a dictionary to map parameters to indices\n        param_to_index = {param: i for i, param in enumerate(sorted(parameters))}\n\n        # Create the correlation matrix\n        correlation_matrix = np.eye(len(parameters))\n        for param1, param2, correlation in self.input_data:\n            i = param_to_index[param1]\n            j = param_to_index[param2]\n            correlation_matrix[i, j] = correlation\n            correlation_matrix[j, i] = correlation\n\n        # Display the correlation matrix\n        self.table_widget.setRowCount(len(parameters))\n        self.table_widget.setColumnCount(len(parameters))\n        self.table_widget.setHorizontalHeaderLabels(sorted(parameters))\n        self.table_widget.setVerticalHeaderLabels(sorted(parameters))\n        for i, param1 in enumerate(sorted(parameters)):\n            for j, param2 in enumerate(sorted(parameters)):\n                self.table_widget.setItem(i, j, QTableWidgetItem(str(correlation_matrix[i, j])))\n\n    def commit(self):\n        self.Outputs.correlation_matrix = self.correlation_matrix\n\nif __name__ == "__main__":\n    import sys\n    app = QApplication(sys.argv)\n    widget = CorrelationMatrixWidget()\n    widget.show()\n    data = [("A", "B", 0.5), ("A", "C", 0.2), ("B", "C", 0.8), ("A", "A", 1), ("B", "B", 1), ("C", "C", 1)]\n    widget.set_input_data(data)\n    app.exec_()\n', 'filename': '/Users/wolf/Documents/FH-Burgenland/F&amp;E_Projekte/RTR_Medienvertrauen&amp;KI/correlation_matrix_widget.py'}, {'name': 'correlation_matrix.py', 'script': '#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\nCreated on 14/05/2025\n\n@author: Wolfram C. Rinke (c) 1990-2025\n\n"""\nimport numpy as np\nfrom numpy import asarray\nimport sys\nfrom Orange.data import Table, Domain, ContinuousVariable, DiscreteVariable, StringVariable\n\nclass CorrelationMatrix():\n    name = "Correlation Matrix"\n    description = "Generate a correlation matrix from a list of triples"\n    icon = "icons/correlation_matrix.svg"\n    data = None\n    correlation_matrix = None\n    featurelist = None\n\n    def set_data(self, data):\n        self.data = data\n        self.generate_correlation_matrix()\n\n    def get_sorted_features(self):\n        return(self.featurelist)\n    \n    def get_output_data(self):\n        return(self.correlation_matrix)\n\n    def generate_correlation_matrix(self):\n        if self.data is None:\n            return\n\n        # Get unique parameters\n        parameters = set()\n        ndata = len(self.data)\n        for i in range(ndata):\n            param1, param2 = self.data.metas[i]\n            parameters.add(param1)\n            parameters.add(param2)\n        self.featurelist = sorted(parameters)\n        # Create a dictionary to map parameters to indices\n        param_to_index = {param: i for i, param in enumerate(self.featurelist)}\n\n        #print(param_to_index)\n        #print(self.data)\n        # Create the correlation matrix\n        self.correlation_matrix = np.eye(len(parameters))\n        for i in range(ndata):\n            param1, param2 = self.data.metas[i]\n            correlation = self.data[i][0]\n            i = param_to_index[param1]\n            j = param_to_index[param2]\n            self.correlation_matrix[i, j] = correlation\n            self.correlation_matrix[j, i] = correlation\n\n\ncm = CorrelationMatrix()\ncm.set_data(in_data)\ndata = cm.get_output_data()\n\nX=list()\nattrList = []\nfeaturelist = cm.get_sorted_features()\nfor feature in featurelist:\n    fattr = [ContinuousVariable(feature, number_of_decimals=2)]\n    attrList.extend(fattr)\ndomain = Domain(attributes=attrList, metas=[StringVariable("Features")])\n\ncorrdata = Table.from_list(domain,data)\nfor i in range(len(featurelist)):\n    corrdata.metas[i] = featurelist[i]\nout_data = corrdata\n', 'filename': '/Users/wolf/Documents/FH-Burgenland/F&amp;E_Projekte/RTR_Medienvertrauen&amp;KI/correlation_matrix.py'}, {'name': 'dependency_matrix_20250726_orange3.38.py', 'script': '#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\nCreated on Sun Mar 11 07:04:39 2018\n\n@author: Wolfram C. Rinke (c) 1990-2023\n\n    Revison:  2018-04-24 (new functionality to split elasticity across class-values)\n              2018-05-11 (semi elasticity calculation)correct\n              2021-10-13 (added machineEpsylon for accuracy)\n              2022-04-22 (fix changes in referencing arrays and rows)\n    \n    Description: in_data is the training data\n                 in_learner is the trained ANN model\n                 \n                 The algorithm only accepts numeric attributes, but multi inputs and multi output attributes\n                 it calculates the first order derivative do/di between each input and each output node for each\n                 data sample.\n                \n"""\nimport Orange\nfrom Orange.data import Table, Domain\nfrom Orange.data import ContinuousVariable, DiscreteVariable, StringVariable\nimport numpy as np\nfrom numpy import asarray\nimport math\nimport sklearn.neural_network\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.preprocessing import MinMaxScaler\nimport scipy\nimport sys\n\n# Backprop on the Seeds Dataset\nfrom random import seed\nfrom random import randrange\nfrom random import random\nfrom csv import reader\nfrom math import exp\n\n\nseed(1)\n\ndef machineEpsilon(func=float):\n     machine_epsilon = func(1)\n     while func(1)+func(machine_epsilon) != func(1):\n         machine_epsilon_last = machine_epsilon\n         machine_epsilon = func(machine_epsilon) / func(2)\n     return machine_epsilon_last\n\nclass MLP:\n    dataset = None          # the dataset for training or evaluation\n    sdataset = None         # the dataset for scaling\n    ndataset = None         # normalized dataset\n    dataset_split = None\n    Dataset_fold = None\n    fold_size = 0\n    nhlayer = None\n    network = None\n    row = None              # internal structure to keep weights for each row\n    stats = None            # range for scaling\n    bNormIn = False         # boolean flag if input data is scaled\n    bNormOut = False        # boolean flag if input data is scaled\n    n_sample = 0              # length of loaded dataset\n    n_inputs = 0\n    n_output = 0\n    eps = machineEpsilon(float)\n\n    def __init__(self, dataset, ninp, noutp, scaler=None, nhlayer=(10)):\n        self.dataset = dataset\n        self.n_sample = len(dataset)\n        self.n_inputs = ninp\n        self.n_output = noutp\n        self.nhlayer = nhlayer\n        if (scaler == None):\n            self.scaler = StandardScaler()\n        else:\n            self.scaler = scaler \n        return\n    \n    # Load a CSV file\n    def load_csv(self, filename):\n        self.dataset = list()\n        with open(filename, \'r\') as file:\n            csv_reader = reader(file)\n            for row in csv_reader:\n                if not row:\n                    continue\n                self.dataset.append(row)\n        return self.dataset\n    \n    # Convert string column to float\n    def str_column_to_float(self, column):\n        if (self.dataset != None):\n            for row in self.dataset:\n                row[column] = float(row[column].strip())\n    \n    # Convert string column to integer\n    def str_column_to_int(self, column):\n        if (self.dataset != None):\n            class_values = [row[column] for row in self.dataset]\n            unique = set(class_values)\n            self.lookup = dict()\n            for i, value in enumerate(unique):\n                self.lookup[value] = i\n            for row in self.dataset:\n                row[column] = self.lookup[row[column]]\n        else:\n            self.lookup = None\n        return self.lookup\n    \n    # Rescale dataset according to scaler\n    def normalize_dataset(self, binp=True, boutp=True):\n        self.bNormIn = binp\n        self.bNormOut = boutp\n        self.ndataset = None\n        self.xinp = None\n        self.yinp = None\n        if (self.scaler != None):\n           # print(self.dataset)\n           self.scaler.fit(asarray(self.dataset))\n           # print(self.dataset)\n           if (binp or boutp):\n                self.ndataset = self.scaler.transform(asarray(self.dataset))\n           else:\n                self.ndataset = asarray(self.dataset)\n           # print(self.ndataset) \n        return self.ndataset\n    \n    \n    # Split a dataset into k folds\n    def cross_validation_split(self, n_folds):\n        dataset_split = list()\n        dataset_copy = list(self.dataset)\n        self.fold_size = int(len(self.dataset) / n_folds)\n        for i in range(n_folds):\n            fold = list()\n            while len(fold) &lt; self.fold_size:\n                index = randrange(len(dataset_copy))\n                fold.append(dataset_copy.pop(index))\n            dataset_split.append(fold)\n        return dataset_split\n    \n    # Calculate accuracy percentage\n    def accuracy_metric(self, actual, predicted):\n        correct = 0\n        for i in range(len(actual)):\n            if actual[i] == predicted[i]:\n                correct += 1\n        return correct / float(len(actual)) * 100.0\n    \n    # Calculate accuracy percentage\n    def accuracy_metric_regress(self, actual, predicted):\n        correct = 0.0\n        for i in range(len(actual)):\n            if (actual[i] &gt; 0.0):\n                res = (1.0 - abs((predicted[i] - actual[i])/actual[i]))\n            else:\n                res = (1.0 - abs(predicted[i]))\n            if (res &gt;= 0.0):\n                correct += res\n        return correct / float(len(actual)) * 100.0\n    \n    \n    # Evaluate an algorithm using a cross validation split\n    def evaluate_algorithm(self, algorithm, n_folds, *args):\n        dataset = self.dataset\n        if (n_folds &lt; 2):\n            n_folds = 2\n        if (n_folds &gt; (len(dataset) - 1)):\n            n_folds = (len(dataset) - 1)\n        folds = self.cross_validation_split(dataset, n_folds)\n        scores = list()\n        for fold in folds:\n            train_set = list(folds)\n            train_set.remove(fold)\n            train_set = sum(train_set, [])\n            test_set = list()\n            for row in fold:\n                row_copy = list(row)\n                test_set.append(row_copy)\n                row_copy[-1] = None\n            predicted, network = self.algorithm(train_set, test_set, *args)\n            actual = [row[-1] for row in fold]\n            accuracy = self.accuracy_metric(actual, predicted)\n            scores.append(accuracy)\n        return scores, network\n    \n    # Evaluate an algorithm using a cross validation split\n    def evaluate_algorithm_regress(self, algorithm, n_folds, *args):\n        dataset = self.dataset\n        scores = list()\n        if (n_folds &lt; 2):\n            n_folds = 2\n        if (n_folds &gt; (len(dataset) - 1)):\n            n_folds = (len(dataset) - 1)\n        folds = self.cross_validation_split(n_folds)\n        for fold in folds:\n            train_set = list(folds)\n            train_set.remove(fold)\n            train_set = sum(train_set, [])\n            test_set = list()\n            for row in fold:\n                row_copy = list(row)\n                test_set.append(row_copy)\n                #row_copy[-1] = None\n            predicted = algorithm(train_set, test_set, *args)\n            actual = [row[-1] for row in fold]\n            accuracy = self.accuracy_metric_regress(actual, predicted)\n            scores.append(accuracy)\n        return scores\n    \n    \n    # Calculate neuron activation for an input\n    def activate(self, weights, inputs):\n        activation = weights[-1]\n        for i in range(len(weights)-1):\n            activation += weights[i] * inputs[i]\n        return activation\n    \n    # Transfer neuron activation\n    def transfer(self, activation):\n        try:\n            val = 1.0 / (1.0 + exp(-activation))\n        except:\n            if (activation &gt; 100):\n                val = 1.0\n            elif (activation &lt; -100):\n                val = 0.0\n        return val\n    \n    # Calculate the derivative of an neuron output\n    def transfer_derivative(self, output):\n        return output * (1.0 - output)\n    \n    # Transfer neuron activation\n    def transferLin(self, activation):\n        return activation\n    \n    # Calculate the derivative of an neuron output\n    def transferLin_derivative(self, output):\n        return 1.0\n    \n    \n    # Forward propagate input to a network output\n    def forward_propagate(self, row, deriv=False, LinOut=False):\n        network = self.network\n        nL = len(network)\n        inputs = row\n        for l in range(nL):\n            layer = network[l]\n            new_inputs = []\n            for neuron in layer:\n                activation = self.activate(neuron[\'weights\'], inputs)\n                if (l == (nL - 1)) and LinOut:\n                    neuron[\'output\'] = activation\n                else:    \n                    neuron[\'output\'] = self.transfer(activation)\n                new_inputs.append(neuron[\'output\'])\n                if (deriv):\n                    if (l == (nL - 1)) and LinOut:\n                        neuron[\'delta\'] = 1.0\n                    else:\n                        neuron[\'delta\'] = self.transfer_derivative(neuron[\'output\'])\n            inputs = new_inputs\n        return inputs\n    \n    # Backpropagate error and store in neurons\n    def backward_propagate_error(self, expected, LinOut=False):\n        network = self.network\n        nL = len(network)-1\n        for i in reversed(range(nL+1)):\n            layer = network[i]\n            errors = list()\n            if i != nL:\n                for j in range(len(layer)):\n                    error = 0.0\n                    for neuron in network[i + 1]:\n                        error += (neuron[\'weights\'][j] * neuron[\'delta\'])\n                    errors.append(error)\n            else:\n                for j in range(len(layer)):\n                    neuron = layer[j]\n                    errors.append(expected[j] - neuron[\'output\'])\n            for j in range(len(layer)):\n                neuron = layer[j]\n                if (i == nL) and LinOut:\n                    deriv = neuron[\'output\']\n                else:\n                    deriv = self.transfer_derivative(neuron[\'output\'])\n                neuron[\'delta\'] = errors[j] * deriv\n    \n    # Update network weights with error\n    def update_weights(self, row, l_rate):\n        network = self.network\n        for i in range(len(network)):\n            inputs = row[:-1]\n            if i != 0:\n                inputs = [neuron[\'output\'] for neuron in network[i - 1]]\n            for neuron in network[i]:\n                for j in range(len(inputs)):\n                    neuron[\'weights\'][j] += l_rate * neuron[\'delta\'] * inputs[j]\n                neuron[\'weights\'][-1] += l_rate * neuron[\'delta\']\n    \n    # Train a network for a fixed number of epochs\n    def train_network(self, train, l_rate, n_epoch, n_outputs, verbose=False, LinOut=False):\n        network = self.network\n        for epoch in range(n_epoch):\n            sum_error = 0\n            for row in train:\n                outputs = self.forward_propagate(row, LinOut=LinOut)\n                expected = [0 for i in range(n_outputs)]\n                expected[row[-1]] = 1\n                sum_error += sum([(expected[i]-outputs[i])**2 for i in range(len(expected))])\n                self.backward_propagate_error(expected, LinOut=LinOut)\n                self.update_weights(network, row, l_rate)\n            if (verbose):\n                print(\'&gt;epoch=%d, lrate=%.3f, error=%.3f\' % (epoch, l_rate, sum_error))\n    \n    # Train a network for a fixed number of epochs\n    def train_network_regress(self, train, l_rate, n_epoch, n_outputs, verbose=False, LinOut=False):\n        #network = self.network\n        n_inp = len(train[0]) - n_outputs - 1\n        for epoch in range(n_epoch):\n            sum_error = 0\n            for row in train:\n                outputs = self.forward_propagate(row, LinOut=LinOut)\n                expected = [row[n_inp - i] for i in range(len(outputs))]\n                #expected[row[-1]] = 1\n                sum_error += sum([(expected[i]-outputs[i])**2 for i in range(len(expected))])\n                self.backward_propagate_error(expected, LinOut=LinOut)\n                self.update_weights(row, l_rate)\n            if (verbose):\n                print(\'&gt;epoch=%d, lrate=%.3f, error=%.3f\' % (epoch, l_rate, sum_error))\n    \n    \n    # Initialize a network\n    def initialize_network(self, n_inputs, n_hidden, n_outputs):\n        self.network = list()\n        hidden_layer = [{\'weights\':[random() for i in range(n_inputs + 1)]} for i in range(n_hidden)]\n        self.network.append(hidden_layer)\n        output_layer = [{\'weights\':[random() for i in range(n_hidden + 1)]} for i in range(n_outputs)]\n        self.network.append(output_layer)\n    #    jacobi_matrix = [{\'jacobi\':[0 for i in range(n_inputs)]} for i in range(n_outputs)]\n    #    network.append(jacobi_matrix)\n        return self.network\n    \n    \n    # Make a prediction with a network\n    def predict(self, row):\n        outputs = self.forward_propagate(row)\n        return outputs.index(max(outputs))\n    \n    def predict_regress(self, row, out=0, deriv=False, LinOut=False):\n        outputs = self.forward_propagate(row, deriv, LinOut=LinOut)\n        return outputs[out]\n    \n    # Backpropagation Algorithm With Stochastic Gradient Descent\n    def back_propagation(self, train, test, l_rate, n_epoch, n_hidden):\n        n_inputs = len(train[0]) - 1\n        n_outputs = len(set([row[-1] for row in train]))\n        # print(n_inputs, n_outputs)\n        self.network = self.initialize_network(n_inputs, n_hidden, n_outputs)\n        self.train_network(train, l_rate, n_epoch, n_outputs)\n        predictions = list()\n        for row in test:\n            prediction = self.predict(row)\n            predictions.append(prediction)\n        return(predictions)\n    \n    # Backpropagation Algorithm With Stochastic Gradient Descent\n    def back_propagation_regress(self, train, test, l_rate, n_epoch, n_hidden, LinOut=False):\n        n_inputs = len(train[0]) - 1\n        n_outputs = 1\n        self.network = self.initialize_network(n_inputs, n_hidden, n_outputs)\n        self.train_network_regress(train, l_rate, n_epoch, n_outputs, LinOut=LinOut)\n        predictions = list()\n        for row in test:\n            prediction = self.predict_regress(row, 0, LinOut=LinOut)\n            predictions.append(prediction)\n        return(predictions)\n    \n    # calculate dependence matrix\n        \n        \n    # load skl_network weights and bias into network structure\n    def load_skl_network(self, weights, bias):\n        self.network = list()\n        n_layer = len(weights) - 1\n        n_outputs = 1\n        l_hidden = list()\n        n_hidden = 0\n        n_inputs = 0\n        hidden_layer = None\n        for l in range(n_layer):\n            n_hidden = len(weights[l][0])\n            l_hidden.append(n_hidden)\n            n_inputs = len(weights[l])\n            hidden_layer = [{\'weights\':[0 for j in range(n_inputs + 1)]} for i in range(n_hidden)]    \n            for i in range(n_hidden):\n                for j in range(n_inputs):\n                    hidden_layer[i][\'weights\'][j] = weights[l][j][i]\n                hidden_layer[i][\'weights\'][n_inputs] = bias[l][i]    \n            self.network.append(hidden_layer)\n        n_outputs = np.array(weights[n_layer]).shape\n        n_outputs = n_outputs[1]\n        output_layer = [{\'weights\':[0 for j in range(n_hidden + 1)]} for i in range(n_outputs)]\n        for i in range(n_outputs):\n            for j in range(n_hidden):\n                output_layer[i][\'weights\'][j] = weights[-1][j][i]\n            output_layer[i][\'weights\'][l_hidden[-1]] = bias[-1][i]    \n        self.network.append(output_layer)\n        self.n_layer = n_layer\n        self.n_inputs = n_inputs\n        self.n_hidden = n_hidden\n        self.n_output = n_outputs\n        self.l_hidden = l_hidden\n        return self.network\n        \n    #/* derivative for oputput layer */\n    def calc_dOkdHNi(self, h, o, j):\n        network = self.network\n        #/* output layer for the PEs in hidden layer N */\n        wgt = network[j][o][\'weights\'][h]\n        deriv = network[j][o][\'delta\'] * wgt\n        #print("output layer (calc_dOkdHNi) layer %i node I %i zu node O %i wgt=%f out=%f deriv=%f\\n" % j,i,o,wgt,out,deriv)\n        return deriv\n    \n    # derivaties for hidden layer\n    def calc_dOkdHji(self, i, k, j):\n        network = self.network\n        if (j == 1): #/* j refers to the output layer; all layers are zero indexed */\n            deriv = self.calc_dOkdHNi(i, k, j)\n        else: \n            n_hidden = len(network[0])\n            deriv = 0\n            #/* output layer for the PEs in hidden layer j */\n            for l in range(n_hidden):\n                delta = network[j][l][\'delta\']\n                #delta = network[j][l][\'output\']\n                wgt =  network[j][l][\'weights\'][i]  # /* weigth between in(i) and hd(l) */\n                out = self.calc_dOkdHji(l, k, j+1)\n                deriv += out * delta * wgt\n        # print("Input&amp;hidden layer (calc_dOkdHji) layer=%i i=%i o=%i node %i hid=%f wgt=%f out=%f deriv=%f\\n" % j,l,i,k,hid,wgt,out,deriv);\n        return deriv        \n        \n     # Train a network for a fixed number of epochs\n    def jacobi_network_regress(self, row, LinOut=False, LnOut=False, doElast=True):\n        network = self.network\n        n_inputs = len(network[0][0][\'weights\'])-1\n        outlayer = network[-1]\n        n_outputs = len(outlayer)\n        #  [{\'weights\':[0 for j in range(n_hidden + 1)]} for i in range(n_outputs)]\n        jacobi = [[0.0 for j in range(n_inputs)] for i in range(n_outputs)]    \n        elast = [[0.0 for j in range(n_inputs)] for i in range(n_outputs)] \n        self.forward_propagate(row, deriv=True, LinOut=LinOut)      \n        # calc inputlayer\n        unscalerow = (self.scaler.inverse_transform(asarray(row).reshape(1,-1)))[0]\n        #print(unscalerow)\n        for oi in range(n_outputs):\n             for ii in range(n_inputs):\n                 pd = self.calc_dOkdHji(ii, oi, 0)\n                 ui = unscalerow[ii]\n                 if (doElast):\n                     if (LnOut):\n                         # semi elast type B %-change vs dependent tick-change\n                         el = pd*(ui/math.exp(outlayer[oi][\'output\']))\n                     else:\n                         if (outlayer[oi][\'output\'] != 0):\n                             el = pd*(ui/outlayer[oi][\'output\'])\n                 else:\n                     # semi elast type A tick-change vs dependent %-change\n                     # or just equal to partial derivative\n                     el = pd\n                 elast[oi][ii] = el\n                 jacobi[oi][ii] = pd\n        return jacobi, elast\n        \n      \n    def dependency(self, LinOut=True, LnOut=False, qData=None, nqData=0, offB1=False, doElast=False):\n        network = self.network\n        data = self.ndataset\n        n_inputs = len(network[0][0][\'weights\'])-1\n        n_outputs = len(network[-1])\n        n_samp = len(data)\n        doQsplit = (qData != None)\n        \n        depend = [[0.0 for j in range(n_inputs)] for i in range(n_outputs)]    \n        avg_elast = [[0.0 for j in range(n_inputs)] for i in range(n_outputs)]\n        de_data = list()\n        # following data is only for AAWE journal\n        if (nqData &lt; 1 or qData==None):\n            doQsplit = False\n        qa_elast = None\n        qa_dep = None\n        if (doQsplit):\n            qa_elast = [[[0.0 for j in range(n_inputs+1)] for i in range(nqData)] for i in range(n_outputs)]\n            qa_dep = [[[0.0 for j in range(n_inputs+1)] for i in range(nqData)] for i in range(n_outputs)]\n        for rw in range(n_samp):\n            row = data[rw]\n            urow = self.dataset[rw]\n            jacobi, elast = self.jacobi_network_regress(row, LinOut=LinOut, LnOut=LnOut, doElast=doElast)\n            if (doQsplit):\n                # print(row[qData])\n                q = int(urow[qData])\n            if (offB1):\n                q -= 1\n            for o in range(n_outputs):\n                jl = jacobi[o].copy()\n                jl.extend(elast[o])\n                de_data.append(jl)\n                if (doQsplit):\n                    qa_elast[o][q][n_inputs] += 1\n                    qa_dep[o][q][n_inputs] += 1\n                for i in range(n_inputs):\n                    jc = jacobi[o][i]\n                    el = elast[o][i] \n                    depend[o][i] += abs(jc)\n                    avg_elast[o][i] += el\n                    if (doQsplit):\n                        qa_elast[o][q][i] += el\n                        qa_dep[o][q][i] += abs(jc)\n                        \n        for o in range(n_outputs):\n            if (n_samp &gt; 1):\n                for i in range(n_inputs):\n                    depend[o][i] /= n_samp\n                    avg_elast[o][i] /= n_samp\n            #    \n            if (doQsplit):\n                for q in range(nqData):\n                    nq = qa_elast[o][q][n_inputs]\n                    if (nq &gt; 1):\n                        for i in range(n_inputs):\n                            qa_elast[o][q][i] /= nq \n                            qa_dep[o][q][i] /= nq\n                    qa_dep[o][q][n_inputs] = 0\n                    mm = max(qa_dep[o][q])\n                    if (mm &gt; 0):\n                        for i in range(n_inputs):\n                            qa_dep[o][q][i] /= mm\n            # skale dependency\n            mm = max(depend[o])  \n            if (mm &gt; 0):\n                for i in range(n_inputs):\n                    depend[o][i] /= mm\n        return depend, avg_elast, de_data, qa_elast, qa_dep\n\ndata = in_data\nann = in_object.skl_model\nsklann = MLP(data,0,0)\nsklann.normalize_dataset(boutp=False)\n \nsklann.load_skl_network(ann.coefs_, ann.intercepts_)\n\ndoQsplit=False\n#clData = \'Alter\'\n#clIndex = 0\nclData = \'Bildungsstand\'\nclIndex = 1\nclassList = data.domain.metas[clIndex].values\n#classList = None\n\nif doQsplit:\n    print(data.domain.metas[clIndex].values)\n    if classList :\n        nQdata = len(classList)\n    else:\n        clData = None\n        nQdata = 0\nelse:\n    clData = None\n    nQdata = 0\n\nqa_elast = None\n \ndep,elast,de_data,qa_elast,qa_dep = sklann.dependency(LinOut=True, LnOut=False,\n                                        qData=clData, nqData=nQdata, offB1=False, doElast=True)\n\nattributes = data.domain.attributes\nlattr = len(attributes)\npd_attributes = [ContinuousVariable("pd_"+attributes[i].name) for i in range(lattr)]\nel_attributes = [ContinuousVariable("el_"+attributes[i].name) for i in range(lattr)]\npd_attributes.extend(el_attributes)\nde_data_domain = Domain(attributes=pd_attributes)\nde_data_table = Table.from_list(de_data_domain, de_data)\n\nout_object = de_data_table\n\nX = list()\nM = list()\nL = None\n\nattrList = [ContinuousVariable("dependency", number_of_decimals=3),\n             ContinuousVariable("avg.elast", number_of_decimals=4),\n             ContinuousVariable("abs.avg.elast", number_of_decimals=4)]\nif (doQsplit and clData != None):\n    for i in range(nQdata):\n        if (classList == None):\n            attrList.append(ContinuousVariable("pd_Class_"+str(i+1), number_of_decimals=4))\n            attrList.append(ContinuousVariable("el_Class_"+str(i+1), number_of_decimals=4))\n        else:\n            attrList.append(ContinuousVariable("pd_"+classList[i], number_of_decimals=4))\n            attrList.append(ContinuousVariable("el_"+classList[i], number_of_decimals=4))\n\ndomain = Domain(attributes=attrList, metas=[StringVariable("Attributes")])\n   \n#print(qa_elast)\n#print(dep)    \nfor i in range(len(dep[0])):\n    for j in range(len(dep)):\n        #print(data.domain.attributes[i], dep[j][i])\n        #print("{:30s}\\t{:1.4f}\\t{:1.6f}".format(data.domain.attributes[i].name, dep[j][i], elast[j][i]))\n        L = list()\n        L.append(dep[j][i])\n        L.append(elast[j][i])\n        L.append(abs(elast[j][i]))\n        if (doQsplit):\n            for q in range(nQdata):\n                L.append(qa_dep[j][q][i])\n                L.append(qa_elast[j][q][i])\n        X.append(L)\n        \nscoredata = Table.from_list(domain, X)\nfor i in range(len(dep[0])):\n    scoredata.metas[i] = data.domain.attributes[i].name\nout_data = scoredata\n\n#print(scoredata)\n\nout_object = de_data_table\n        \n#print(erg)\n\n#domain = Domain([ContinuousVariable(\'dependency\'), ContinuousVariable("elasticity")],None,[StringVariable("Name")])\n\n#out_data = Table.from_numpy(erg,None,nam)            \n##    \n#print("++++++++++++++++++++++++++++++++++++")\n#print("finished")\n', 'filename': '/Users/wolf/Documents/FH-Burgenland/F&amp;E_Projekte/RTR_Medienvertrauen&amp;KI/dependency_matrix_20250726_orange3.38.py'}], 'scriptText': '#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n"""\nCreated on Sun Mar 11 07:04:39 2018\n\n@author: Wolfram C. Rinke (c) 1990-2023\n\n    Revison:  2018-04-24 (new functionality to split elasticity across class-values)\n              2018-05-11 (semi elasticity calculation)correct\n              2021-10-13 (added machineEpsylon for accuracy)\n              2022-04-22 (fix changes in referencing arrays and rows)\n    \n    Description: in_data is the training data\n                 in_learner is the trained ANN model\n                 \n                 The algorithm only accepts numeric attributes, but multi inputs and multi output attributes\n                 it calculates the first order derivative do/di between each input and each output node for each\n                 data sample.\n                \n"""\nimport Orange\nfrom Orange.data import Table, Domain\nfrom Orange.data import ContinuousVariable, DiscreteVariable, StringVariable\nimport numpy as np\nfrom numpy import asarray\nimport math\nimport sklearn.neural_network\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.preprocessing import MinMaxScaler\nimport scipy\nimport sys\n\n# Backprop on the Seeds Dataset\nfrom random import seed\nfrom random import randrange\nfrom random import random\nfrom csv import reader\nfrom math import exp\n\n\nseed(1)\n\ndef machineEpsilon(func=float):\n     machine_epsilon = func(1)\n     while func(1)+func(machine_epsilon) != func(1):\n         machine_epsilon_last = machine_epsilon\n         machine_epsilon = func(machine_epsilon) / func(2)\n     return machine_epsilon_last\n\nclass MLP:\n    dataset = None          # the dataset for training or evaluation\n    sdataset = None         # the dataset for scaling\n    ndataset = None         # normalized dataset\n    dataset_split = None\n    Dataset_fold = None\n    fold_size = 0\n    nhlayer = None\n    network = None\n    row = None              # internal structure to keep weights for each row\n    stats = None            # range for scaling\n    bNormIn = False         # boolean flag if input data is scaled\n    bNormOut = False        # boolean flag if input data is scaled\n    n_sample = 0              # length of loaded dataset\n    n_inputs = 0\n    n_output = 0\n    eps = machineEpsilon(float)\n\n    def __init__(self, dataset, ninp, noutp, scaler=None, nhlayer=(10)):\n        self.dataset = dataset\n        self.n_sample = len(dataset)\n        self.n_inputs = ninp\n        self.n_output = noutp\n        self.nhlayer = nhlayer\n        if (scaler == None):\n            self.scaler = StandardScaler()\n        else:\n            self.scaler = scaler \n        return\n    \n    # Load a CSV file\n    def load_csv(self, filename):\n        self.dataset = list()\n        with open(filename, \'r\') as file:\n            csv_reader = reader(file)\n            for row in csv_reader:\n                if not row:\n                    continue\n                self.dataset.append(row)\n        return self.dataset\n    \n    # Convert string column to float\n    def str_column_to_float(self, column):\n        if (self.dataset != None):\n            for row in self.dataset:\n                row[column] = float(row[column].strip())\n    \n    # Convert string column to integer\n    def str_column_to_int(self, column):\n        if (self.dataset != None):\n            class_values = [row[column] for row in self.dataset]\n            unique = set(class_values)\n            self.lookup = dict()\n            for i, value in enumerate(unique):\n                self.lookup[value] = i\n            for row in self.dataset:\n                row[column] = self.lookup[row[column]]\n        else:\n            self.lookup = None\n        return self.lookup\n    \n    # Rescale dataset according to scaler\n    def normalize_dataset(self, binp=True, boutp=True):\n        self.bNormIn = binp\n        self.bNormOut = boutp\n        self.ndataset = None\n        self.xinp = None\n        self.yinp = None\n        if (self.scaler != None):\n           # print(self.dataset)\n           self.scaler.fit(asarray(self.dataset))\n           # print(self.dataset)\n           if (binp or boutp):\n                self.ndataset = self.scaler.transform(asarray(self.dataset))\n           else:\n                self.ndataset = asarray(self.dataset)\n           # print(self.ndataset) \n        return self.ndataset\n    \n    \n    # Split a dataset into k folds\n    def cross_validation_split(self, n_folds):\n        dataset_split = list()\n        dataset_copy = list(self.dataset)\n        self.fold_size = int(len(self.dataset) / n_folds)\n        for i in range(n_folds):\n            fold = list()\n            while len(fold) &lt; self.fold_size:\n                index = randrange(len(dataset_copy))\n                fold.append(dataset_copy.pop(index))\n            dataset_split.append(fold)\n        return dataset_split\n    \n    # Calculate accuracy percentage\n    def accuracy_metric(self, actual, predicted):\n        correct = 0\n        for i in range(len(actual)):\n            if actual[i] == predicted[i]:\n                correct += 1\n        return correct / float(len(actual)) * 100.0\n    \n    # Calculate accuracy percentage\n    def accuracy_metric_regress(self, actual, predicted):\n        correct = 0.0\n        for i in range(len(actual)):\n            if (actual[i] &gt; 0.0):\n                res = (1.0 - abs((predicted[i] - actual[i])/actual[i]))\n            else:\n                res = (1.0 - abs(predicted[i]))\n            if (res &gt;= 0.0):\n                correct += res\n        return correct / float(len(actual)) * 100.0\n    \n    \n    # Evaluate an algorithm using a cross validation split\n    def evaluate_algorithm(self, algorithm, n_folds, *args):\n        dataset = self.dataset\n        if (n_folds &lt; 2):\n            n_folds = 2\n        if (n_folds &gt; (len(dataset) - 1)):\n            n_folds = (len(dataset) - 1)\n        folds = self.cross_validation_split(dataset, n_folds)\n        scores = list()\n        for fold in folds:\n            train_set = list(folds)\n            train_set.remove(fold)\n            train_set = sum(train_set, [])\n            test_set = list()\n            for row in fold:\n                row_copy = list(row)\n                test_set.append(row_copy)\n                row_copy[-1] = None\n            predicted, network = self.algorithm(train_set, test_set, *args)\n            actual = [row[-1] for row in fold]\n            accuracy = self.accuracy_metric(actual, predicted)\n            scores.append(accuracy)\n        return scores, network\n    \n    # Evaluate an algorithm using a cross validation split\n    def evaluate_algorithm_regress(self, algorithm, n_folds, *args):\n        dataset = self.dataset\n        scores = list()\n        if (n_folds &lt; 2):\n            n_folds = 2\n        if (n_folds &gt; (len(dataset) - 1)):\n            n_folds = (len(dataset) - 1)\n        folds = self.cross_validation_split(n_folds)\n        for fold in folds:\n            train_set = list(folds)\n            train_set.remove(fold)\n            train_set = sum(train_set, [])\n            test_set = list()\n            for row in fold:\n                row_copy = list(row)\n                test_set.append(row_copy)\n                #row_copy[-1] = None\n            predicted = algorithm(train_set, test_set, *args)\n            actual = [row[-1] for row in fold]\n            accuracy = self.accuracy_metric_regress(actual, predicted)\n            scores.append(accuracy)\n        return scores\n    \n    \n    # Calculate neuron activation for an input\n    def activate(self, weights, inputs):\n        activation = weights[-1]\n        for i in range(len(weights)-1):\n            activation += weights[i] * inputs[i]\n        return activation\n    \n    # Transfer neuron activation\n    def transfer(self, activation):\n        try:\n            val = 1.0 / (1.0 + exp(-activation))\n        except:\n            if (activation &gt; 100):\n                val = 1.0\n            elif (activation &lt; -100):\n                val = 0.0\n        return val\n    \n    # Calculate the derivative of an neuron output\n    def transfer_derivative(self, output):\n        return output * (1.0 - output)\n    \n    # Transfer neuron activation\n    def transferLin(self, activation):\n        return activation\n    \n    # Calculate the derivative of an neuron output\n    def transferLin_derivative(self, output):\n        return 1.0\n    \n    \n    # Forward propagate input to a network output\n    def forward_propagate(self, row, deriv=False, LinOut=False):\n        network = self.network\n        nL = len(network)\n        inputs = row\n        for l in range(nL):\n            layer = network[l]\n            new_inputs = []\n            for neuron in layer:\n                activation = self.activate(neuron[\'weights\'], inputs)\n                if (l == (nL - 1)) and LinOut:\n                    neuron[\'output\'] = activation\n                else:    \n                    neuron[\'output\'] = self.transfer(activation)\n                new_inputs.append(neuron[\'output\'])\n                if (deriv):\n                    if (l == (nL - 1)) and LinOut:\n                        neuron[\'delta\'] = 1.0\n                    else:\n                        neuron[\'delta\'] = self.transfer_derivative(neuron[\'output\'])\n            inputs = new_inputs\n        return inputs\n    \n    # Backpropagate error and store in neurons\n    def backward_propagate_error(self, expected, LinOut=False):\n        network = self.network\n        nL = len(network)-1\n        for i in reversed(range(nL+1)):\n            layer = network[i]\n            errors = list()\n            if i != nL:\n                for j in range(len(layer)):\n                    error = 0.0\n                    for neuron in network[i + 1]:\n                        error += (neuron[\'weights\'][j] * neuron[\'delta\'])\n                    errors.append(error)\n            else:\n                for j in range(len(layer)):\n                    neuron = layer[j]\n                    errors.append(expected[j] - neuron[\'output\'])\n            for j in range(len(layer)):\n                neuron = layer[j]\n                if (i == nL) and LinOut:\n                    deriv = neuron[\'output\']\n                else:\n                    deriv = self.transfer_derivative(neuron[\'output\'])\n                neuron[\'delta\'] = errors[j] * deriv\n    \n    # Update network weights with error\n    def update_weights(self, row, l_rate):\n        network = self.network\n        for i in range(len(network)):\n            inputs = row[:-1]\n            if i != 0:\n                inputs = [neuron[\'output\'] for neuron in network[i - 1]]\n            for neuron in network[i]:\n                for j in range(len(inputs)):\n                    neuron[\'weights\'][j] += l_rate * neuron[\'delta\'] * inputs[j]\n                neuron[\'weights\'][-1] += l_rate * neuron[\'delta\']\n    \n    # Train a network for a fixed number of epochs\n    def train_network(self, train, l_rate, n_epoch, n_outputs, verbose=False, LinOut=False):\n        network = self.network\n        for epoch in range(n_epoch):\n            sum_error = 0\n            for row in train:\n                outputs = self.forward_propagate(row, LinOut=LinOut)\n                expected = [0 for i in range(n_outputs)]\n                expected[row[-1]] = 1\n                sum_error += sum([(expected[i]-outputs[i])**2 for i in range(len(expected))])\n                self.backward_propagate_error(expected, LinOut=LinOut)\n                self.update_weights(network, row, l_rate)\n            if (verbose):\n                print(\'&gt;epoch=%d, lrate=%.3f, error=%.3f\' % (epoch, l_rate, sum_error))\n    \n    # Train a network for a fixed number of epochs\n    def train_network_regress(self, train, l_rate, n_epoch, n_outputs, verbose=False, LinOut=False):\n        #network = self.network\n        n_inp = len(train[0]) - n_outputs - 1\n        for epoch in range(n_epoch):\n            sum_error = 0\n            for row in train:\n                outputs = self.forward_propagate(row, LinOut=LinOut)\n                expected = [row[n_inp - i] for i in range(len(outputs))]\n                #expected[row[-1]] = 1\n                sum_error += sum([(expected[i]-outputs[i])**2 for i in range(len(expected))])\n                self.backward_propagate_error(expected, LinOut=LinOut)\n                self.update_weights(row, l_rate)\n            if (verbose):\n                print(\'&gt;epoch=%d, lrate=%.3f, error=%.3f\' % (epoch, l_rate, sum_error))\n    \n    \n    # Initialize a network\n    def initialize_network(self, n_inputs, n_hidden, n_outputs):\n        self.network = list()\n        hidden_layer = [{\'weights\':[random() for i in range(n_inputs + 1)]} for i in range(n_hidden)]\n        self.network.append(hidden_layer)\n        output_layer = [{\'weights\':[random() for i in range(n_hidden + 1)]} for i in range(n_outputs)]\n        self.network.append(output_layer)\n    #    jacobi_matrix = [{\'jacobi\':[0 for i in range(n_inputs)]} for i in range(n_outputs)]\n    #    network.append(jacobi_matrix)\n        return self.network\n    \n    \n    # Make a prediction with a network\n    def predict(self, row):\n        outputs = self.forward_propagate(row)\n        return outputs.index(max(outputs))\n    \n    def predict_regress(self, row, out=0, deriv=False, LinOut=False):\n        outputs = self.forward_propagate(row, deriv, LinOut=LinOut)\n        return outputs[out]\n    \n    # Backpropagation Algorithm With Stochastic Gradient Descent\n    def back_propagation(self, train, test, l_rate, n_epoch, n_hidden):\n        n_inputs = len(train[0]) - 1\n        n_outputs = len(set([row[-1] for row in train]))\n        # print(n_inputs, n_outputs)\n        self.network = self.initialize_network(n_inputs, n_hidden, n_outputs)\n        self.train_network(train, l_rate, n_epoch, n_outputs)\n        predictions = list()\n        for row in test:\n            prediction = self.predict(row)\n            predictions.append(prediction)\n        return(predictions)\n    \n    # Backpropagation Algorithm With Stochastic Gradient Descent\n    def back_propagation_regress(self, train, test, l_rate, n_epoch, n_hidden, LinOut=False):\n        n_inputs = len(train[0]) - 1\n        n_outputs = 1\n        self.network = self.initialize_network(n_inputs, n_hidden, n_outputs)\n        self.train_network_regress(train, l_rate, n_epoch, n_outputs, LinOut=LinOut)\n        predictions = list()\n        for row in test:\n            prediction = self.predict_regress(row, 0, LinOut=LinOut)\n            predictions.append(prediction)\n        return(predictions)\n    \n    # calculate dependence matrix\n        \n        \n    # load skl_network weights and bias into network structure\n    def load_skl_network(self, weights, bias):\n        self.network = list()\n        n_layer = len(weights) - 1\n        n_outputs = 1\n        l_hidden = list()\n        n_hidden = 0\n        n_inputs = 0\n        hidden_layer = None\n        for l in range(n_layer):\n            n_hidden = len(weights[l][0])\n            l_hidden.append(n_hidden)\n            n_inputs = len(weights[l])\n            hidden_layer = [{\'weights\':[0 for j in range(n_inputs + 1)]} for i in range(n_hidden)]    \n            for i in range(n_hidden):\n                for j in range(n_inputs):\n                    hidden_layer[i][\'weights\'][j] = weights[l][j][i]\n                hidden_layer[i][\'weights\'][n_inputs] = bias[l][i]    \n            self.network.append(hidden_layer)\n        n_outputs = np.array(weights[n_layer]).shape\n        n_outputs = n_outputs[1]\n        output_layer = [{\'weights\':[0 for j in range(n_hidden + 1)]} for i in range(n_outputs)]\n        for i in range(n_outputs):\n            for j in range(n_hidden):\n                output_layer[i][\'weights\'][j] = weights[-1][j][i]\n            output_layer[i][\'weights\'][l_hidden[-1]] = bias[-1][i]    \n        self.network.append(output_layer)\n        self.n_layer = n_layer\n        self.n_inputs = n_inputs\n        self.n_hidden = n_hidden\n        self.n_output = n_outputs\n        self.l_hidden = l_hidden\n        return self.network\n        \n    #/* derivative for oputput layer */\n    def calc_dOkdHNi(self, h, o, j):\n        network = self.network\n        #/* output layer for the PEs in hidden layer N */\n        wgt = network[j][o][\'weights\'][h]\n        deriv = network[j][o][\'delta\'] * wgt\n        #print("output layer (calc_dOkdHNi) layer %i node I %i zu node O %i wgt=%f out=%f deriv=%f\\n" % j,i,o,wgt,out,deriv)\n        return deriv\n    \n    # derivaties for hidden layer\n    def calc_dOkdHji(self, i, k, j):\n        network = self.network\n        if (j == 1): #/* j refers to the output layer; all layers are zero indexed */\n            deriv = self.calc_dOkdHNi(i, k, j)\n        else: \n            n_hidden = len(network[0])\n            deriv = 0\n            #/* output layer for the PEs in hidden layer j */\n            for l in range(n_hidden):\n                delta = network[j][l][\'delta\']\n                #delta = network[j][l][\'output\']\n                wgt =  network[j][l][\'weights\'][i]  # /* weigth between in(i) and hd(l) */\n                out = self.calc_dOkdHji(l, k, j+1)\n                deriv += out * delta * wgt\n        # print("Input&amp;hidden layer (calc_dOkdHji) layer=%i i=%i o=%i node %i hid=%f wgt=%f out=%f deriv=%f\\n" % j,l,i,k,hid,wgt,out,deriv);\n        return deriv        \n        \n     # Train a network for a fixed number of epochs\n    def jacobi_network_regress(self, row, LinOut=False, LnOut=False, doElast=True):\n        network = self.network\n        n_inputs = len(network[0][0][\'weights\'])-1\n        outlayer = network[-1]\n        n_outputs = len(outlayer)\n        #  [{\'weights\':[0 for j in range(n_hidden + 1)]} for i in range(n_outputs)]\n        jacobi = [[0.0 for j in range(n_inputs)] for i in range(n_outputs)]    \n        elast = [[0.0 for j in range(n_inputs)] for i in range(n_outputs)] \n        self.forward_propagate(row, deriv=True, LinOut=LinOut)      \n        # calc inputlayer\n        unscalerow = (self.scaler.inverse_transform(asarray(row).reshape(1,-1)))[0]\n        #print(unscalerow)\n        for oi in range(n_outputs):\n             for ii in range(n_inputs):\n                 pd = self.calc_dOkdHji(ii, oi, 0)\n                 ui = unscalerow[ii]\n                 if (doElast):\n                     if (LnOut):\n                         # semi elast type B %-change vs dependent tick-change\n                         el = pd*(ui/math.exp(outlayer[oi][\'output\']))\n                     else:\n                         if (outlayer[oi][\'output\'] != 0):\n                             el = pd*(ui/outlayer[oi][\'output\'])\n                 else:\n                     # semi elast type A tick-change vs dependent %-change\n                     # or just equal to partial derivative\n                     el = pd\n                 elast[oi][ii] = el\n                 jacobi[oi][ii] = pd\n        return jacobi, elast\n        \n      \n    def dependency(self, LinOut=True, LnOut=False, qData=None, nqData=0, offB1=False, doElast=False):\n        network = self.network\n        data = self.ndataset\n        n_inputs = len(network[0][0][\'weights\'])-1\n        n_outputs = len(network[-1])\n        n_samp = len(data)\n        doQsplit = (qData != None)\n        \n        depend = [[0.0 for j in range(n_inputs)] for i in range(n_outputs)]    \n        avg_elast = [[0.0 for j in range(n_inputs)] for i in range(n_outputs)]\n        de_data = list()\n        # following data is only for AAWE journal\n        if (nqData &lt; 1 or qData==None):\n            doQsplit = False\n        qa_elast = None\n        qa_dep = None\n        if (doQsplit):\n            qa_elast = [[[0.0 for j in range(n_inputs+1)] for i in range(nqData)] for i in range(n_outputs)]\n            qa_dep = [[[0.0 for j in range(n_inputs+1)] for i in range(nqData)] for i in range(n_outputs)]\n        for rw in range(n_samp):\n            row = data[rw]\n            urow = self.dataset[rw]\n            jacobi, elast = self.jacobi_network_regress(row, LinOut=LinOut, LnOut=LnOut, doElast=doElast)\n            if (doQsplit):\n                # print(row[qData])\n                q = int(urow[qData])\n            if (offB1):\n                q -= 1\n            for o in range(n_outputs):\n                jl = jacobi[o].copy()\n                jl.extend(elast[o])\n                de_data.append(jl)\n                if (doQsplit):\n                    qa_elast[o][q][n_inputs] += 1\n                    qa_dep[o][q][n_inputs] += 1\n                for i in range(n_inputs):\n                    jc = jacobi[o][i]\n                    el = elast[o][i] \n                    depend[o][i] += abs(jc)\n                    avg_elast[o][i] += el\n                    if (doQsplit):\n                        qa_elast[o][q][i] += el\n                        qa_dep[o][q][i] += abs(jc)\n                        \n        for o in range(n_outputs):\n            if (n_samp &gt; 1):\n                for i in range(n_inputs):\n                    depend[o][i] /= n_samp\n                    avg_elast[o][i] /= n_samp\n            #    \n            if (doQsplit):\n                for q in range(nqData):\n                    nq = qa_elast[o][q][n_inputs]\n                    if (nq &gt; 1):\n                        for i in range(n_inputs):\n                            qa_elast[o][q][i] /= nq \n                            qa_dep[o][q][i] /= nq\n                    qa_dep[o][q][n_inputs] = 0\n                    mm = max(qa_dep[o][q])\n                    if (mm &gt; 0):\n                        for i in range(n_inputs):\n                            qa_dep[o][q][i] /= mm\n            # skale dependency\n            mm = max(depend[o])  \n            if (mm &gt; 0):\n                for i in range(n_inputs):\n                    depend[o][i] /= mm\n        return depend, avg_elast, de_data, qa_elast, qa_dep\n\ndata = in_data\nann = in_object.skl_model\nsklann = MLP(data,0,0)\nsklann.normalize_dataset(boutp=False)\n \nsklann.load_skl_network(ann.coefs_, ann.intercepts_)\n\ndoQsplit=False\n#clData = \'Alter\'\n#clIndex = 0\nclData = \'Bildungsstand\'\nclIndex = 1\nclassList = data.domain.metas[clIndex].values\n#classList = None\n\nif doQsplit:\n    print(data.domain.metas[clIndex].values)\n    if classList :\n        nQdata = len(classList)\n    else:\n        clData = None\n        nQdata = 0\nelse:\n    clData = None\n    nQdata = 0\n\nqa_elast = None\n \ndep,elast,de_data,qa_elast,qa_dep = sklann.dependency(LinOut=True, LnOut=False,\n                                        qData=clData, nqData=nQdata, offB1=False, doElast=True)\n\nattributes = data.domain.attributes\nlattr = len(attributes)\npd_attributes = [ContinuousVariable("pd_"+attributes[i].name) for i in range(lattr)]\nel_attributes = [ContinuousVariable("el_"+attributes[i].name) for i in range(lattr)]\npd_attributes.extend(el_attributes)\nde_data_domain = Domain(attributes=pd_attributes)\nde_data_table = Table.from_list(de_data_domain, de_data)\n\nout_object = de_data_table\n\nX = list()\nM = list()\nL = None\n\nattrList = [ContinuousVariable("dependency", number_of_decimals=3),\n             ContinuousVariable("avg.elast", number_of_decimals=4),\n             ContinuousVariable("abs.avg.elast", number_of_decimals=4)]\nif (doQsplit and clData != None):\n    for i in range(nQdata):\n        if (classList == None):\n            attrList.append(ContinuousVariable("pd_Class_"+str(i+1), number_of_decimals=4))\n            attrList.append(ContinuousVariable("el_Class_"+str(i+1), number_of_decimals=4))\n        else:\n            attrList.append(ContinuousVariable("pd_"+classList[i], number_of_decimals=4))\n            attrList.append(ContinuousVariable("el_"+classList[i], number_of_decimals=4))\n\ndomain = Domain(attributes=attrList, metas=[StringVariable("Attributes")])\n   \n#print(qa_elast)\n#print(dep)    \nfor i in range(len(dep[0])):\n    for j in range(len(dep)):\n        #print(data.domain.attributes[i], dep[j][i])\n        #print("{:30s}\\t{:1.4f}\\t{:1.6f}".format(data.domain.attributes[i].name, dep[j][i], elast[j][i]))\n        L = list()\n        L.append(dep[j][i])\n        L.append(elast[j][i])\n        L.append(abs(elast[j][i]))\n        if (doQsplit):\n            for q in range(nQdata):\n                L.append(qa_dep[j][q][i])\n                L.append(qa_elast[j][q][i])\n        X.append(L)\n        \nscoredata = Table.from_list(domain, X)\nfor i in range(len(dep[0])):\n    scoredata.metas[i] = data.domain.attributes[i].name\nout_data = scoredata\n\n#print(scoredata)\n\nout_object = de_data_table\n        \n#print(erg)\n\n#domain = Domain([ContinuousVariable(\'dependency\'), ContinuousVariable("elasticity")],None,[StringVariable("Name")])\n\n#out_data = Table.from_numpy(erg,None,nam)            \n##    \n#print("++++++++++++++++++++++++++++++++++++")\n#print("finished")\n', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xab\x00\x00\x00k\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
